# ==================================================
# Lumin SaaS - Environment Variables Template
# ==================================================
# Copy this file to .env for local development
# In Render, set these as Environment Variables

# ==================================================
# DJANGO CORE SETTINGS
# ==================================================

# Secret key for cryptographic signing (REQUIRED)
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here

# Debug mode (True for development, False for production)
DEBUG=True

# Django settings module to use
DJANGO_SETTINGS_MODULE=config.settings.development

# ==================================================
# DATABASE
# ==================================================

# PostgreSQL connection string (Production - Render will auto-provide this)
# DATABASE_URL=postgresql://user:password@host:port/database

# For local development with PostgreSQL:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/lumin_db

# Leave empty to use SQLite (default for development)
# DATABASE_URL=

# ==================================================
# REDIS CACHE & CELERY
# ==================================================

# Redis connection URL (Production - Render will auto-provide this)
REDIS_URL=redis://localhost:6379/0

# ==================================================
# ALLOWED HOSTS & CORS
# ==================================================

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of CORS allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# CSRF trusted origins (for production)
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# ==================================================
# AWS S3 FILE STORAGE (Optional)
# ==================================================

# Enable S3 storage (True for production, False for local)
USE_S3=False

# AWS credentials (only needed if USE_S3=True)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# ==================================================
# EMAIL SERVICE (SendGrid)
# ==================================================

# SendGrid API key for sending emails
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Default "from" email address
DEFAULT_FROM_EMAIL=noreply@lumin.app

# ==================================================
# SMS SERVICE (Twilio - Optional)
# ==================================================

# Twilio credentials for SMS verification
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ==================================================
# GOOGLE OAUTH (Optional)
# ==================================================

# Google OAuth credentials
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# ==================================================
# SESSION SETTINGS
# ==================================================

# Session cookie age in seconds (default: 1200 = 20 minutes)
SESSION_COOKIE_AGE=1200

# Save session on every request
SESSION_SAVE_EVERY_REQUEST=True

# HttpOnly flag for session cookie
SESSION_COOKIE_HTTPONLY=True

# SameSite attribute for session cookie
SESSION_COOKIE_SAMESITE=Lax

# ==================================================
# SECURITY SETTINGS (Production Only)
# ==================================================

# Force HTTPS redirect (True in production)
SECURE_SSL_REDIRECT=False

# HTTP Strict Transport Security (seconds)
SECURE_HSTS_SECONDS=0

# ==================================================
# NOTES
# ==================================================
#
# 1. WooCommerce API keys are NOT stored here!
#    They are managed per-tenant in the database.
#
# 2. For Render deployment:
#    - DATABASE_URL and REDIS_URL are auto-provided
#    - Set SECRET_KEY to "generateValue: true" in render.yaml
#    - Add other secrets manually in Render dashboard
#
# 3. Never commit the actual .env file to git!
#    Add .env to .gitignore
#
